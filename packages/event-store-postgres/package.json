{
    "name": "@dcb-es/event-store-postgres",
    "description": "Postgres adapter for @dcb-es/event-store — persistent DCB event store with optimistic concurrency and tag-based querying",
    "author": "Paul Grimshaw",
    "license": "BSD-3-Clause",
    "version": "7.0.0-alpha.2",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "build": "tsc -p tsconfig.json",
        "watch": "tsc -w -p tsconfig.json",
        "lint": "eslint \"**/*.ts\" .",
        "lint-fix": "eslint \"**/*.ts\" . --fix",
        "prepublishOnly": "test \"$CHANGESET_PUBLISH\" = '1' || (echo 'Use: pnpm run release (from repo root)' && exit 1)"
    },
    "keywords": [
        "event-sourcing",
        "event-store",
        "dcb",
        "dynamic-consistency-boundary",
        "postgres",
        "cqrs",
        "typescript"
    ],
    "homepage": "https://github.com/kraken-tech/dcb-event-store#readme",
    "bugs": {
        "url": "https://github.com/kraken-tech/dcb-event-store/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kraken-tech/dcb-event-store.git",
        "directory": "packages/event-store-postgres"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@dcb-es/event-store": "workspace:*",
        "pg": "^8.11.5",
        "pg-copy-streams": "^7.0.0"
    },
    "devDependencies": {
        "@testcontainers/postgresql": "^10.9.0",
        "@types/pg": "^8.11.6",
        "@types/pg-copy-streams": "^1.2.5",
        "testcontainers": "^10.9.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
